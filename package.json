{
  "name": "universe",
  "private": true,
  "version": "0.1.0",
  "description": "Real-time 3D Earth with surrounding asteroids, satellites, and live planetary data",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @universe/api dev",
    "dev:web": "pnpm --filter @universe/web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @universe/api build",
    "build:web": "pnpm --filter @universe/web build",
    "deploy:api": "pnpm --filter @universe/api deploy",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf node_modules dist .nuxt .output .wrangler"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
